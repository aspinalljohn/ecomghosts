{% extends "base.njk" %}

{% block head %}
<!-- Article Structured Data -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title }}",
    "description": "{{ description }}",
    "author": {
        "@type": "Person",
        "name": "{{ author or site.author }}",
        "url": "{{ site.social.linkedinPersonal }}"
    },
    "publisher": {
        "@type": "Organization",
        "name": "{{ site.name }}",
        "logo": {
            "@type": "ImageObject",
            "url": "{{ site.url }}{{ site.logo }}"
        }
    },
    "datePublished": "{{ date | isoDate }}",
    {% if modified %}"dateModified": "{{ modified | isoDate }}",{% endif %}
    "wordCount": {{ content | wordCount }},
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ site.url }}{{ page.url }}"
    },
    "image": "{{ ogImage or (site.url + '/img/og-image.png') }}"
}
</script>

<!-- BreadcrumbList Structured Data -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ site.url }}"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "Blog",
            "item": "{{ site.url }}/blog/"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{ title }}",
            "item": "{{ site.url }}{{ page.url }}"
        }
    ]
}
</script>
{% endblock %}

{% block content %}
<article class="blog-article">
    <div class="container">
        <div class="blog-article-header">
            <nav class="breadcrumb" aria-label="Breadcrumb">
                <a href="/">Home</a> <span class="breadcrumb-sep">/</span>
                <a href="/blog/">Blog</a> <span class="breadcrumb-sep">/</span>
                <span>{{ title }}</span>
            </nav>
            <h1 class="blog-article-title">{{ title }}</h1>
            <div class="blog-article-meta">
                <span class="blog-article-author">By {{ author or site.author }}</span>
                <span class="blog-article-sep">&middot;</span>
                <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
                <span class="blog-article-sep">&middot;</span>
                <span>{{ content | readingTime }}</span>
            </div>
        </div>

        <div class="blog-article-body">
            {{ content | safe }}
        </div>

        <!-- Post Navigation -->
        {% set previousPost = collections.blog | getPreviousCollectionItem(page) %}
        {% set nextPost = collections.blog | getNextCollectionItem(page) %}

        {% if previousPost or nextPost %}
        <nav class="blog-post-nav" aria-label="Post navigation">
            {% if previousPost %}
            <a href="{{ previousPost.url }}" class="blog-post-nav-link prev">
                <span class="blog-post-nav-label">&larr; Previous</span>
                <span class="blog-post-nav-title">{{ previousPost.data.title }}</span>
            </a>
            {% else %}
            <div></div>
            {% endif %}
            {% if nextPost %}
            <a href="{{ nextPost.url }}" class="blog-post-nav-link next">
                <span class="blog-post-nav-label">Next &rarr;</span>
                <span class="blog-post-nav-title">{{ nextPost.data.title }}</span>
            </a>
            {% endif %}
        </nav>
        {% endif %}

        <!-- CTA -->
        <div class="blog-cta">
            <h2>Ready to turn your LinkedIn into a revenue channel?</h2>
            <p>We write operator-level content for e-commerce founders. No fluff. No generic posts. Just content that drives pipeline.</p>
            <a href="{{ site.social.calendar }}" class="btn-primary" target="_blank">Book a Strategy Call</a>
        </div>
    </div>
</article>
{% endblock %}
